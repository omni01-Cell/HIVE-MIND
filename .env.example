# ============================================
# HIVE-MIND V3 - Configuration Environnement
# ============================================
# Copiez ce fichier vers .env et remplissez vos valeurs

# =================== DATABASE ===================
# Supabase (requis) - https://supabase.com
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-service-role-key

# Redis Cloud (requis) - https://upstash.com ou https://redis.com
REDIS_URL=redis://default:password@host:port

# =================== IA PROVIDERS ===================
# Au moins un provider IA est requis

# OpenAI - https://platform.openai.com
VOTRE_CLE_OPENAI=sk-your-openai-key

# Google Gemini (recommandé, gratuit) - https://aistudio.google.com
VOTRE_CLE_GEMINI=your-gemini-api-key

# Anthropic Claude - https://console.anthropic.com
VOTRE_CLE_ANTHROPIC=your-anthropic-api-key

# Mistral AI
VOTRE_CLE_MISTRAL=your-mistral-api-key

# Kimi / Moonshot
VOTRE_CLE_KIMI=your-kimi-key
VOTRE_CLE_MOONSHOT=your-moonshot-key

# Github Models
VOTRE_CLE_GITHUB=your-github-token

# Groq (pour transcription vocale et inférence rapide) - https://console.groq.com
VOTRE_CLE_GROQ=your-groq-api-key

# Minimax (pour TTS premium et modèles)
VOTRE_CLE_MINIMAX=your-minimax-api-key

# HuggingFace
VOTRE_CLE_HF=your-hf-token

# =================== CONFIGURATION BOT ===================
# Timezone du bot (pour le scheduler)
TZ=Europe/Paris

# Mode debug (active les logs verbeux)
DEBUG=false
