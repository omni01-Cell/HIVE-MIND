# ============================================
# HIVE-MIND V1 - Configuration Environnement
# ============================================
# Copiez ce fichier vers .env et remplissez vos valeurs

# =================== DATABASE ===================
# Supabase (requis) - https://supabase.com
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-service-role-key

# Redis Cloud (requis) - https://upstash.com ou https://redis.com
REDIS_URL=redis://default:password@host:port

# =================== IA PROVIDERS (Smart Router V2) ===================
# HIVE-MIND supporte la rotation automatique jusqu'à 7 clés par fournisseur.
# Format: PROVIDER_KEY_1, PROVIDER_KEY_2, ... PROVIDER_KEY_7
# Format unique supporté: PROVIDER_KEY_N (pas de VOTRE_CLE_*).

# Gemini (Google AI Studio) - Recommandé (Gratuit et Puissant)
GEMINI_KEY_1=your-first-key
GEMINI_KEY_2=your-second-key
# ... jusqu'à GEMINI_KEY_7

# Groq (Inférence Ultra-Rapide)
GROQ_KEY_1=your-first-key
GROQ_KEY_2=your-second-key

# Mistral AI
MISTRAL_KEY_1=your-mistral-key-1

# Codestral (Mistral AI — Endpoint dédié code & agentic — https://console.mistral.ai/api-keys/)
# Limites: 30 RPM, 2 000 RPD. Modèle phare EXECUTOR + PLANNER du harnais.
CODESTRAL_KEY=your-codestral-key

# Kimi / Moonshot
KIMI_KEY_1=your-kimi-key-1
MOONSHOT_KEY_1=your-moonshot-key-1

# Minimax (pour TTS premium et modèles)
MINIMAX_KEY_1=your-minimax-key-1

# HuggingFace
HUGGINGFACE_KEY_1=your-hf-token-1

# NVIDIA API (integrate.api.nvidia.com) - ex: moonshotai/kimi-k2.5
NVIDIA_KEY_1=your-nvidia-api-key-1

# OpenRouter (openrouter.ai) - Gateway multi-provider rapide
OPENROUTER_KEY_1=your-openrouter-api-key-1

# SerpApi (Google AI Mode search) - https://serpapi.com
SERPAPI_KEY=your-serpapi-key

# =================== CONFIGURATION BOT ===================
# Timezone du bot (pour le scheduler)
TZ=Europe/Paris



# Mode debug (active les logs verbeux)
DEBUG=false

# Accusés de réception WhatsApp (rend le bot plus humain)
# SEND_DELIVERY_RECEIPTS: envoie une notification de réception (double coche grise)
SEND_DELIVERY_RECEIPTS=true

# SEND_READ_RECEIPTS: envoie une notoification de lecture (double coche bleue)
SEND_READ_RECEIPTS=true

# =================== PROGRAMMATIC TOOL CALLING (PTC) ===================
# Permet au LLM de générer du JS pour orchestrer plusieurs outils d'un coup
# Au lieu de faire N allers-retours, le bot fait 1 exécution locale
PTC_ENABLED=true
PTC_TIMEOUT_MS=30000

# =================== BROWSER AGENT (agent-browser) ===================
# Auto-shutdown daemon après 5min d'inactivité
AGENT_BROWSER_IDLE_TIMEOUT_MS=300000
# Optionnel: blacklist de domaines séparés par des virgules (ouverte par défaut)
# AGENT_BROWSER_BLOCKED_DOMAINS=malware-domain.com,onion.ws

# =================== CODEX OAUTH PROVIDER ===================
# Authentification OAuth pour consommer l'abonnement ChatGPT Plus/Pro
# CODEX_ACCESS_TOKEN=your-access-token
# CODEX_REFRESH_TOKEN=your-refresh-token
# CODEX_ACCOUNT_ID=your-account-id

# =================== GOOGLE OAUTH PROVIDERS ===================
# Google Antigravity (Cloud Code Assist Premium)
ANTIGRAVITY_CLIENT_ID=your-antigravity-client-id
ANTIGRAVITY_CLIENT_SECRET=your-antigravity-client-secret
ANTIGRAVITY_REFRESH_TOKEN=your-antigravity-refresh-token
ANTIGRAVITY_PROJECT_ID=rising-fact-p41fc

# Google Gemini CLI (GE_*)
GE_CLIENT_ID=your-gemini-cli-client-id
GE_CLIENT_SECRET=your-gemini-cli-client-secret
GE_DEFAULT_PROJECT_ID=rising-fact-p41fc
GEMINI_CLI_REFRESH_TOKEN=your-gemini-cli-refresh-token

