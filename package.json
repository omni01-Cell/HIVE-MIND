{
    "name": "hive-mind",
    "version": "1.0.0",
    "description": "Bot WhatsApp modulaire avec architecture Brick-Like et multi-modèles IA",
    "type": "module",
    "main": "bot.js",
    "bin": {
        "hive-mind": "./bin/hive-mind.js"
    },
    "scripts": {
        "start": "tsx bot.js",
        "dev": "tsx --watch bot.js",
        "build": "tsc --noEmit",
        "lint": "eslint . --ext .js,.ts",
        "lint:fix": "eslint . --ext .js,.ts --fix",
        "cli": "tsx scripts/admin-cli.js",
        "repair": "tsx scripts/repair-session.js",
        "audit:group": "tsx scripts/audit-group.js",
        "fix:usernames": "tsx scripts/fix-missing-usernames.js",
        "test": "tsx --test",
        "test:unit": "tsx --test tests/unit/**/*.test.js",
        "test:supabase": "tsx --test tests/supabase.test.js",
        "test:providers": "tsx --test tests/providers.test.js"
    },
    "keywords": [
        "whatsapp",
        "bot",
        "ai",
        "baileys",
        "supabase"
    ],
    "author": "Christ-Leandre",
    "license": "MIT",
    "dependencies": {
        "@ffmpeg-installer/ffmpeg": "^1.1.0",
        "@google/genai": "^1.37.0",
        "@google/generative-ai": "^0.24.1",
        "@supabase/supabase-js": "^2.39.0",
        "@vitalets/google-translate-api": "^9.2.0",
        "@whiskeysockets/baileys": "^6.7.0",
        "ajv": "^8.17.1",
        "cheerio": "^1.1.2",
        "cli-progress": "^3.12.0",
        "dotenv": "^17.2.3",
        "fluent-ffmpeg": "^2.1.3",
        "groq-sdk": "^0.37.0",
        "json5": "^2.2.3",
        "jsonrepair": "^3.13.2",
        "node-cron": "^3.0.3",
        "node-gtts": "^2.0.2",
        "pdfkit": "^0.17.2",
        "pino": "^8.17.0",
        "qrcode-terminal": "^0.12.0",
        "redis": "^4.6.12",
        "wa-sticker-formatter": "^4.4.4",
        "wikipedia": "^2.1.2",
        "ws": "^8.19.0",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@types/node": "^25.6.0",
        "eslint": "^9.39.2",
        "tsx": "^4.21.0",
        "typescript": "^6.0.3"
    }
}
