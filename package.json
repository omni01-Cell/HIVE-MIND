{
  "name": "hive-mind",
  "version": "1.0.0",
  "description": "Bot WhatsApp modulaire avec architecture Brick-Like et multi-modèles IA",
  "type": "module",
  "main": "src/bin/hive-mind.ts",
  "bin": {
    "hive-mind": "./src/bin/hive-mind.ts"
  },
  "scripts": {
    "start": "tsx src/bin/hive-mind.ts start",
    "dev": "tsx --watch src/bin/hive-mind.ts start",
    "build": "tsc --noEmit",
    "lint": "eslint . --ext .js,.ts",
    "lint:fix": "eslint . --ext .js,.ts --fix",
    "tui": "APP_ENV=local tsx src/tui/index.tsx",
    "repair": "tsx src/scripts/repair-session.ts",
    "audit:group": "tsx src/scripts/audit-group.ts",
    "fix:usernames": "tsx src/scripts/fix-missing-usernames.ts",
    "test": "NODE_ENV=test SUPABASE_URL=http://localhost:54321 SUPABASE_KEY=dummy REDIS_URL=redis://localhost:6379 NODE_OPTIONS='--experimental-vm-modules' jest --forceExit",
    "test:unit": "NODE_ENV=test SUPABASE_URL=http://localhost:54321 SUPABASE_KEY=dummy REDIS_URL=redis://localhost:6379 NODE_OPTIONS='--experimental-vm-modules' jest src/tests/unit",
    "test:integration": "NODE_ENV=test SUPABASE_URL=http://localhost:54321 SUPABASE_KEY=dummy REDIS_URL=redis://localhost:6379 NODE_OPTIONS='--experimental-vm-modules' jest src/tests/integration",
    "test:e2e": "NODE_ENV=test SUPABASE_URL=http://localhost:54321 SUPABASE_KEY=dummy REDIS_URL=redis://localhost:6379 NODE_OPTIONS='--experimental-vm-modules' jest src/tests/e2e",
    "postinstall": "npx playwright install chromium",
    "prepare": "husky"
  },
  "keywords": [
    "whatsapp",
    "bot",
    "ai",
    "baileys",
    "supabase"
  ],
  "author": "Christ-Leandre",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.101.0",
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@google/genai": "^1.37.0",
    "@google/generative-ai": "^0.24.1",
    "@iarna/toml": "^2.2.5",
    "@jrichman/ink": "^6.6.9",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@supabase/supabase-js": "^2.39.0",
    "@types/diff": "^7.0.2",
    "@vitalets/google-translate-api": "^9.2.0",
    "@whiskeysockets/baileys": "^6.7.0",
    "@xterm/headless": "^6.0.0",
    "acorn": "^8.16.0",
    "acorn-walk": "^8.3.5",
    "agent-browser": "latest",
    "ajv": "^8.17.1",
    "audio-decode": "^2.2.3",
