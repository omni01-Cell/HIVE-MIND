    "@types/node": "^25.6.0",
    "@types/node-cron": "^3.0.11",
    "@types/react": "^19.2.14",
    "@types/ws": "^8.18.1",
    "eslint": "^9.39.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.9",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.4"
  }
}
